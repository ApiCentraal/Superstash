# Superstash Backend Environment Variables

# Database
DATABASE_URL=postgresql://saasuser:saaspass@localhost:5432/saasdashboard

# Server
NODE_ENV=development
PORT=4000

# Authentication
JWT_SECRET=your-secret-key-change-in-production

# Redis (voor BullMQ en caching)
REDIS_URL=redis://localhost:6379

# Payment Providers (optioneel)
STRIPE_API_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
SQUARE_ACCESS_TOKEN=

# Analytics Providers (optioneel)
GOOGLE_ANALYTICS_API_KEY=
MATOMO_API_URL=
MATOMO_API_TOKEN=

# Logging
LOG_LEVEL=info
